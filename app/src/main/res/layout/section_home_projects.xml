<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/projects_frame"
        style="?attr/materialCardViewElevatedStyle"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen140dp"
        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
        app:cardCornerRadius="@dimen/dimen28dp"
        app:cardElevation="0dp"
        app:strokeWidth="@dimen/dimen0dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/dimen20dp">

            <TextView
                android:id="@+id/projects_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/number_label"
                android:textColor="?attr/colorOnSecondaryContainer"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineLarge"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen12dp"
                android:text="@string/total"
                android:textColor="?attr/colorOnSecondaryContainer"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textStyle="bold"
                app:layout_constraintBaseline_toBaselineOf="@id/projects_count"
                app:layout_constraintStart_toEndOf="@id/projects_count" />

            <TextView
                android:id="@+id/projects_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/projects"
                android:textColor="?attr/colorOnSecondaryContainer"
                android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <ImageView
                android:layout_width="@dimen/dimen96dp"
                android:layout_height="@dimen/dimen96dp"
                android:alpha="0.15"
                android:contentDescription="@string/generic_img_copy"
                android:src="@drawable/ic_projects_home"
                app:tint="?attr/colorOnSecondaryContainer"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/groups_frame"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:layout_marginTop="@dimen/dimen16dp"
        android:layout_marginEnd="@dimen/dimen8dp"
        app:cardBackgroundColor="?attr/colorTertiaryContainer"
        app:cardCornerRadius="@dimen/dimen24dp"
        app:cardElevation="0dp"
        app:strokeWidth="@dimen/dimen0dp"
        app:layout_constraintEnd_toStartOf="@+id/guideline_center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/projects_frame">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/dimen16dp">

            <ImageView
                android:id="@+id/groups_icon"
                android:layout_width="@dimen/dimen40dp"
                android:layout_height="@dimen/dimen40dp"
                android:contentDescription="@string/generic_img_copy"
                android:src="@drawable/ic_groups"
                app:tint="?attr/colorOnTertiaryContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/groups_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen8dp"
                android:text="@string/number_label"
                android:textColor="?attr/colorOnTertiaryContainer"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineLarge"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/groups_icon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen8dp"
                android:text="@string/groups"
                android:textColor="?attr/colorOnTertiaryContainer"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                app:layout_constraintBaseline_toBaselineOf="@id/groups_count"
                app:layout_constraintStart_toEndOf="@id/groups_count" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/starred_frame"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:layout_marginTop="@dimen/dimen16dp"
        android:layout_marginStart="@dimen/dimen8dp"
        app:cardBackgroundColor="?attr/colorPrimaryContainer"
        app:cardCornerRadius="@dimen/dimen24dp"
        app:cardElevation="0dp"
        app:strokeWidth="@dimen/dimen0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/guideline_center"
        app:layout_constraintTop_toBottomOf="@id/projects_frame">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/dimen16dp">

            <ImageView
                android:id="@+id/starred_icon"
                android:layout_width="@dimen/dimen40dp"
                android:layout_height="@dimen/dimen40dp"
                android:contentDescription="@string/generic_img_copy"
                android:src="@drawable/ic_star_home"
                app:tint="?attr/colorOnPrimaryContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/starred_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen8dp"
                android:text="@string/number_label"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineLarge"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/starred_icon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen8dp"
                android:text="@string/starred"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                app:layout_constraintBaseline_toBaselineOf="@id/starred_count"
                app:layout_constraintStart_toEndOf="@id/starred_count" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

</androidx.constraintlayout.widget.ConstraintLayout>