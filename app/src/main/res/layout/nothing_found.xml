<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/nothing_found_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:visibility="gone"
    android:padding="@dimen/dimen32dp">

    <View
        android:layout_width="@dimen/dimen110dp"
        android:layout_height="@dimen/dimen110dp"
        android:background="@drawable/shape_circle"
        android:backgroundTint="?attr/colorSurfaceContainerHigh"
        android:alpha="0.5" />

    <ImageView
        android:layout_width="@dimen/dimen84dp"
        android:layout_height="@dimen/dimen84dp"
        android:layout_marginTop="-98dp"
        android:contentDescription="@string/nothing_found"
        android:src="@drawable/ic_nothing_found"
        android:alpha="0.9" />

    <TextView
        android:id="@+id/nothing_found_title"
        style="@style/TextAppearance.Material3.TitleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen32dp"
        android:text="@string/nothing_found_title"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/nothing_found"
        style="@style/TextAppearance.Material3.BodyMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen8dp"
        android:alpha="0.7"
        android:text="@string/nothing_found"
        android:textAlignment="center" />

</LinearLayout>